bin/
gen/
out/
release/
build/
**/build/

# Gradle files
.gradle/
**/.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.ipr
*.iws

# Keystore files (NEVER commit signing keys)
*.jks
*.keystore
key.properties

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Mac
.DS_Store

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Detekt reports
**/reports/

# Kotlin
.kotlin/

# PR description — local working file, mirrors PLAN_Documents convention in sibling repos.
PR_DESCRIPTION.md
